# ─────────────────────────────────────────────────
#  .env.example - Sao chép thành .env và điền giá trị
# ─────────────────────────────────────────────────

# Private key của ví deployer (Hardhat local sẵn có 20 account)
# Không dùng private key thật trên local!
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC URL khi chạy Hardhat Node riêng
RPC_URL=http://127.0.0.1:8545

# (Optional) Sepolia Testnet
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# (Optional) Etherscan API key (để verify contract)
# ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Bật gas reporter khi test
REPORT_GAS=false
